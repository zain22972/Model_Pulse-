# ──────────────────────────────────────────────────────────────────────────────
# Model Pulse — Environment Variables
# Copy this file to .env.local and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# CopilotKit Cloud public API key (required)
# Get yours at https://cloud.copilotkit.ai
NEXT_PUBLIC_COPILOT_CLOUD_PUBLIC_API_KEY=your_copilotkit_public_api_key_here

# Backend-for-Frontend (BFF) URL — LangGraph agent server
# Default: http://localhost:4000 (local dev)
# Production: set to your deployed agent URL
BFF_URL=http://localhost:4000

# Notion integration (optional — only needed for Leads Canvas)
NOTION_TOKEN=
NOTION_LEADS_DATABASE_ID=
